<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" xmlns:modeler="http://camunda.org/schema/modeler/1.0" id="Definitions_LiveFeed" targetNamespace="http://bpmn.io/schema/bpmn" exporter="Camunda Modeler" exporterVersion="5.44.0">
  <bpmn:collaboration id="Collaboration_LiveFeed">
    <bpmn:participant id="Participant_Homeowner" name="Homeowner" processRef="Process_Homeowner" />
    <bpmn:participant id="Participant_ClientApp" name="Client Application" processRef="Process_ClientApp" />
    <bpmn:participant id="Participant_APIGateway" name="API Gateway" processRef="Process_APIGateway" />
    <bpmn:participant id="Participant_DeviceMgmt" name="Device Management Service" processRef="Process_DeviceMgmt" />
    <bpmn:participant id="Participant_VideoService" name="Video Streaming Service" processRef="Process_VideoService" />
    <bpmn:participant id="Participant_IoTFirmware" name="IoT Device Firmware (Camera)" processRef="Process_IoTFirmware" />
    <bpmn:messageFlow id="Flow_HomeownerToApp" sourceRef="Activity_SelectCamera" targetRef="Activity_AppReceivesSelection" />
    <bpmn:messageFlow id="Flow_AppToGateway" sourceRef="Activity_RequestLiveFeed" targetRef="Activity_ReceiveFeedRequest" />
    <bpmn:messageFlow id="Flow_GatewayToDeviceMgmt" sourceRef="Activity_RequestStream" targetRef="Activity_ReceiveRequest" />
    <bpmn:messageFlow id="Flow_DeviceMgmtToFirmware" sourceRef="Activity_SendStreamRequest" targetRef="Activity_ReceiveStreamRequest" />
    <bpmn:messageFlow id="Flow_FirmwareToVideoService" sourceRef="Activity_StreamVideo" targetRef="Activity_IngestStream" />
    <bpmn:messageFlow id="Flow_AppToVideoService" sourceRef="Activity_RequestChunks" targetRef="Activity_ReceiveChunkRequest" />
    <bpmn:messageFlow id="Flow_VideoServiceToApp" sourceRef="Activity_StreamChunks" targetRef="Activity_ReceiveChunks" />
    <bpmn:messageFlow id="Flow_VideoToHomeowner" sourceRef="Activity_RenderVideo" targetRef="Activity_WatchFeed" />
    <bpmn:textAnnotation id="TextAnnotation_Title">
      <bpmn:text>User Views Live Camera Feed Workflow</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:association id="Association_Title" sourceRef="Participant_Homeowner" targetRef="TextAnnotation_Title" />
  </bpmn:collaboration>
  <bpmn:process id="Process_Homeowner" isExecutable="false">
    <bpmn:startEvent id="Event_Start" name="User wants to view camera">
      <bpmn:outgoing>Flow_H1</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:task id="Activity_OpenApp" name="Open Mobile/Web App">
      <bpmn:incoming>Flow_H1</bpmn:incoming>
      <bpmn:outgoing>Flow_H2</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Activity_SelectCamera" name="Select Camera from Dashboard">
      <bpmn:incoming>Flow_H2</bpmn:incoming>
      <bpmn:outgoing>Flow_H3</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Activity_WatchFeed" name="Watch Live Feed">
      <bpmn:incoming>Flow_H3</bpmn:incoming>
      <bpmn:outgoing>Flow_H4</bpmn:outgoing>
    </bpmn:task>
    <bpmn:endEvent id="Event_End" name="Viewing live feed">
      <bpmn:incoming>Flow_H4</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="Flow_H1" sourceRef="Event_Start" targetRef="Activity_OpenApp" />
    <bpmn:sequenceFlow id="Flow_H2" sourceRef="Activity_OpenApp" targetRef="Activity_SelectCamera" />
    <bpmn:sequenceFlow id="Flow_H3" sourceRef="Activity_SelectCamera" targetRef="Activity_WatchFeed" />
    <bpmn:sequenceFlow id="Flow_H4" sourceRef="Activity_WatchFeed" targetRef="Event_End" />
  </bpmn:process>
  <bpmn:process id="Process_ClientApp" isExecutable="false">
    <bpmn:task id="Activity_AppReceivesSelection" name="App Opens to Event View">
      <bpmn:outgoing>Flow_CA1</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Activity_RequestLiveFeed" name="Request Live Camera Feed">
      <bpmn:incoming>Flow_CA1</bpmn:incoming>
      <bpmn:outgoing>Flow_CA2</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Activity_InitPlayer" name="Initialize Player">
      <bpmn:incoming>Flow_CA2</bpmn:incoming>
      <bpmn:outgoing>Flow_CA3</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Activity_RequestChunks" name="Request Chunks">
      <bpmn:incoming>Flow_CA3</bpmn:incoming>
      <bpmn:outgoing>Flow_CA4</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Activity_ReceiveChunks" name="Receive Chunks">
      <bpmn:incoming>Flow_CA4</bpmn:incoming>
      <bpmn:outgoing>Flow_CA5</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Activity_RenderVideo" name="Render Video">
      <bpmn:incoming>Flow_CA5</bpmn:incoming>
    </bpmn:task>
    <bpmn:sequenceFlow id="Flow_CA1" sourceRef="Activity_AppReceivesSelection" targetRef="Activity_RequestLiveFeed" />
    <bpmn:sequenceFlow id="Flow_CA2" sourceRef="Activity_RequestLiveFeed" targetRef="Activity_InitPlayer" />
    <bpmn:sequenceFlow id="Flow_CA3" sourceRef="Activity_InitPlayer" targetRef="Activity_RequestChunks" />
    <bpmn:sequenceFlow id="Flow_CA4" sourceRef="Activity_RequestChunks" targetRef="Activity_ReceiveChunks" />
    <bpmn:sequenceFlow id="Flow_CA5" sourceRef="Activity_ReceiveChunks" targetRef="Activity_RenderVideo" />
  </bpmn:process>
  <bpmn:process id="Process_APIGateway" isExecutable="false">
    <bpmn:task id="Activity_ReceiveFeedRequest" name="Receive Live Feed Request">
      <bpmn:outgoing>Flow_AG1</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Activity_AuthenticateUser" name="Authenticate User">
      <bpmn:incoming>Flow_AG1</bpmn:incoming>
      <bpmn:outgoing>Flow_AG2</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Activity_RequestStream" name="Request Stream from DMS">
      <bpmn:incoming>Flow_AG2</bpmn:incoming>
    </bpmn:task>
    <bpmn:sequenceFlow id="Flow_AG1" sourceRef="Activity_ReceiveFeedRequest" targetRef="Activity_AuthenticateUser" />
    <bpmn:sequenceFlow id="Flow_AG2" sourceRef="Activity_AuthenticateUser" targetRef="Activity_RequestStream" />
  </bpmn:process>
  <bpmn:process id="Process_DeviceMgmt" isExecutable="false">
    <bpmn:task id="Activity_ReceiveRequest" name="Receive Request">
      <bpmn:outgoing>Flow_DM1</bpmn:outgoing>
    </bpmn:task>
    <bpmn:exclusiveGateway id="Gateway_DeviceOnline" name="Device Online?">
      <bpmn:incoming>Flow_DM1</bpmn:incoming>
      <bpmn:outgoing>Flow_DM2_Yes</bpmn:outgoing>
      <bpmn:outgoing>Flow_DM2_No</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:task id="Activity_SendStreamRequest" name="Send Live Feed Request">
      <bpmn:incoming>Flow_DM2_Yes</bpmn:incoming>
    </bpmn:task>
    <bpmn:endEvent id="Event_DeviceOffline" name="Error: Offline">
      <bpmn:incoming>Flow_DM2_No</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="Flow_DM1" sourceRef="Activity_ReceiveRequest" targetRef="Gateway_DeviceOnline" />
    <bpmn:sequenceFlow id="Flow_DM2_Yes" name="Yes" sourceRef="Gateway_DeviceOnline" targetRef="Activity_SendStreamRequest" />
    <bpmn:sequenceFlow id="Flow_DM2_No" name="No" sourceRef="Gateway_DeviceOnline" targetRef="Event_DeviceOffline" />
  </bpmn:process>
  <bpmn:process id="Process_VideoService" isExecutable="false">
    <bpmn:task id="Activity_IngestStream" name="Ingest Live Stream">
      <bpmn:outgoing>Flow_VS1</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Activity_BufferStream" name="Buffer Stream">
      <bpmn:incoming>Flow_VS1</bpmn:incoming>
      <bpmn:outgoing>Flow_VS2</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Activity_ReceiveChunkRequest" name="Receive Chunk Request">
      <bpmn:incoming>Flow_VS2</bpmn:incoming>
      <bpmn:outgoing>Flow_VS3</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Activity_StreamChunks" name="Stream Chunks">
      <bpmn:incoming>Flow_VS3</bpmn:incoming>
    </bpmn:task>
    <bpmn:sequenceFlow id="Flow_VS1" sourceRef="Activity_IngestStream" targetRef="Activity_BufferStream" />
    <bpmn:sequenceFlow id="Flow_VS2" sourceRef="Activity_BufferStream" targetRef="Activity_ReceiveChunkRequest" />
    <bpmn:sequenceFlow id="Flow_VS3" sourceRef="Activity_ReceiveChunkRequest" targetRef="Activity_StreamChunks" />
  </bpmn:process>
  <bpmn:process id="Process_IoTFirmware" isExecutable="false">
    <bpmn:task id="Activity_ReceiveStreamRequest" name="Receive Request">
      <bpmn:outgoing>Flow_IOT1</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Activity_ValidateRequest" name="Validate Request">
      <bpmn:incoming>Flow_IOT1</bpmn:incoming>
      <bpmn:outgoing>Flow_IOT2</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Activity_StreamVideo" name="Stream Video">
      <bpmn:incoming>Flow_IOT2</bpmn:incoming>
    </bpmn:task>
    <bpmn:sequenceFlow id="Flow_IOT1" sourceRef="Activity_ReceiveStreamRequest" targetRef="Activity_ValidateRequest" />
    <bpmn:sequenceFlow id="Flow_IOT2" sourceRef="Activity_ValidateRequest" targetRef="Activity_StreamVideo" />
  </bpmn:process>
