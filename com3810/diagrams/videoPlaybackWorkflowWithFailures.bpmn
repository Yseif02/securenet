<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" xmlns:modeler="http://camunda.org/schema/modeler/1.0" id="Definitions_VideoPlayback" targetNamespace="http://bpmn.io/schema/bpmn" exporter="Camunda Modeler" exporterVersion="5.44.0">
  <bpmn:collaboration id="Collaboration_VideoPlayback">
    <bpmn:participant id="Participant_Homeowner" name="Homeowner" processRef="Process_Homeowner" />
    <bpmn:participant id="Participant_ClientApp" name="Client Application" processRef="Process_ClientApp" />
    <bpmn:participant id="Participant_APIGateway" name="API Gateway" processRef="Process_APIGateway" />
    <bpmn:participant id="Participant_VideoService" name="Video Streaming Service" processRef="Process_VideoService" />
    <bpmn:participant id="Participant_DataStorage" name="Data Storage Layer" processRef="Process_DataStorage" />
    <bpmn:messageFlow id="Flow_HomeownerToApp" sourceRef="Activity_SelectTimeRange" targetRef="Activity_ReceiveSelection" />
    <bpmn:messageFlow id="Flow_AppToGateway" sourceRef="Activity_RequestVideo" targetRef="Activity_ReceiveVideoRequest" />
    <bpmn:messageFlow id="Flow_GatewayToVideo" sourceRef="Activity_RouteToVideo" targetRef="Activity_ReceiveRequest" />
    <bpmn:messageFlow id="Flow_VideoToStorage" sourceRef="Activity_QueryArchive" targetRef="Activity_FindVideos" />
    <bpmn:messageFlow id="Flow_StorageToVideo" sourceRef="Activity_ReturnFiles" targetRef="Activity_ReceiveFiles" />
    <bpmn:messageFlow id="Flow_VideoToGateway" sourceRef="Activity_ReturnStreamURL" targetRef="Activity_ReceiveURL" />
    <bpmn:messageFlow id="Flow_GatewayToApp" sourceRef="Activity_ForwardURL" targetRef="Activity_ReceiveStreamURL" />
    <bpmn:messageFlow id="Flow_AppToStorage" sourceRef="Activity_RequestChunks" targetRef="Activity_StreamChunks" />
    <bpmn:messageFlow id="Flow_StorageToApp" sourceRef="Activity_DeliverChunks" targetRef="Activity_ReceiveChunks" />
    <bpmn:messageFlow id="Flow_0cwfywv" sourceRef="Activity_RenderVideo" targetRef="Activity_WatchVideo" />
    <bpmn:messageFlow id="Flow_StorageLowQualityToApp" sourceRef="Activity_DeliverLowQualityChunks" targetRef="Activity_ShowReducedQuality" />
    <bpmn:textAnnotation id="TextAnnotation_Title">
      <bpmn:text>Video Playback Workflow (with Bandwidth Failure Scenario)</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:association id="Association_Title" sourceRef="Participant_Homeowner" targetRef="TextAnnotation_Title" />
  </bpmn:collaboration>
  <bpmn:process id="Process_Homeowner" isExecutable="false">
    <bpmn:startEvent id="Event_Start" name="User wants to review footage">
      <bpmn:outgoing>Flow_H1</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:task id="Activity_OpenApp" name="Open Mobile/Web App">
      <bpmn:incoming>Flow_H1</bpmn:incoming>
      <bpmn:outgoing>Flow_H2</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Activity_SelectCamera" name="Select Camera">
      <bpmn:incoming>Flow_H2</bpmn:incoming>
      <bpmn:outgoing>Flow_H3</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Activity_NavigateHistory" name="Navigate to History">
      <bpmn:incoming>Flow_H3</bpmn:incoming>
      <bpmn:outgoing>Flow_H4</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Activity_SelectTimeRange" name="Select Time Range">
      <bpmn:incoming>Flow_H4</bpmn:incoming>
      <bpmn:outgoing>Flow_H5</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Activity_WatchVideo" name="Watch Video">
      <bpmn:incoming>Flow_H5</bpmn:incoming>
      <bpmn:outgoing>Flow_H6</bpmn:outgoing>
    </bpmn:task>
    <bpmn:endEvent id="Event_End" name="Footage reviewed">
      <bpmn:incoming>Flow_H6</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="Flow_H1" sourceRef="Event_Start" targetRef="Activity_OpenApp" />
    <bpmn:sequenceFlow id="Flow_H2" sourceRef="Activity_OpenApp" targetRef="Activity_SelectCamera" />
    <bpmn:sequenceFlow id="Flow_H3" sourceRef="Activity_SelectCamera" targetRef="Activity_NavigateHistory" />
    <bpmn:sequenceFlow id="Flow_H4" sourceRef="Activity_NavigateHistory" targetRef="Activity_SelectTimeRange" />
    <bpmn:sequenceFlow id="Flow_H5" sourceRef="Activity_SelectTimeRange" targetRef="Activity_WatchVideo" />
    <bpmn:sequenceFlow id="Flow_H6" sourceRef="Activity_WatchVideo" targetRef="Event_End" />
  </bpmn:process>
  <bpmn:process id="Process_ClientApp" isExecutable="false">
    <bpmn:task id="Activity_ReceiveSelection" name="Receive Selection">
      <bpmn:outgoing>Flow_CA1</bpmn:outgoing>
    </bpmn:task>
    <bpmn:sequenceFlow id="Flow_CA1" sourceRef="Activity_ReceiveSelection" targetRef="Activity_ShowLoading" />
    <bpmn:sequenceFlow id="Flow_CA2" sourceRef="Activity_ShowLoading" targetRef="Activity_RequestVideo" />
    <bpmn:sequenceFlow id="Flow_CA3" sourceRef="Activity_RequestVideo" targetRef="Activity_ReceiveStreamURL" />
    <bpmn:sequenceFlow id="Flow_CA4" sourceRef="Activity_ReceiveStreamURL" targetRef="Activity_InitPlayer" />
    <bpmn:sequenceFlow id="Flow_CA5" sourceRef="Activity_InitPlayer" targetRef="Activity_RequestChunks" />
    <bpmn:sequenceFlow id="Flow_CA6" sourceRef="Activity_RequestChunks" targetRef="Activity_ReceiveChunks" />
    <bpmn:sequenceFlow id="Flow_CA7" sourceRef="Activity_ReceiveChunks" targetRef="Activity_RenderVideo" />
    <bpmn:sequenceFlow id="Flow_CA_BWCheck" sourceRef="Activity_RenderVideo" targetRef="Gateway_BandwidthOK" />
    <bpmn:sequenceFlow id="Flow_CA_BWYes" name="Yes" sourceRef="Gateway_BandwidthOK" targetRef="Event_CA_FullQuality" />
    <bpmn:sequenceFlow id="Flow_CA_BWNo" name="No" sourceRef="Gateway_BandwidthOK" targetRef="Activity_ShowReducedQuality" />
    <bpmn:sequenceFlow id="Flow_CA_MonitorBW" sourceRef="Activity_ShowReducedQuality" targetRef="Gateway_BWRestored" />
    <bpmn:sequenceFlow id="Flow_CA_BWRestored" name="Yes" sourceRef="Gateway_BWRestored" targetRef="Event_CA_QualityRestored" />
    <bpmn:sequenceFlow id="Flow_CA_BWStillLow" name="No" sourceRef="Gateway_BWRestored" targetRef="Event_CA_LowQuality" />
    <bpmn:task id="Activity_ShowReducedQuality" name="Display Playback at Reduced Quality">
      <bpmn:incoming>Flow_CA_BWNo</bpmn:incoming>
      <bpmn:outgoing>Flow_CA_MonitorBW</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Activity_RenderVideo" name="Render Video">
      <bpmn:incoming>Flow_CA7</bpmn:incoming>
      <bpmn:outgoing>Flow_CA_BWCheck</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Activity_ReceiveChunks" name="Receive Chunks">
      <bpmn:incoming>Flow_CA6</bpmn:incoming>
      <bpmn:outgoing>Flow_CA7</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Activity_RequestChunks" name="Request Chunks">
      <bpmn:incoming>Flow_CA5</bpmn:incoming>
      <bpmn:outgoing>Flow_CA6</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Activity_InitPlayer" name="Initialize Player">
      <bpmn:incoming>Flow_CA4</bpmn:incoming>
      <bpmn:outgoing>Flow_CA5</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Activity_ReceiveStreamURL" name="Receive Stream URL">
      <bpmn:incoming>Flow_CA3</bpmn:incoming>
      <bpmn:outgoing>Flow_CA4</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Activity_RequestVideo" name="Request Video">
      <bpmn:incoming>Flow_CA2</bpmn:incoming>
      <bpmn:outgoing>Flow_CA3</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Activity_ShowLoading" name="Show Loading">
      <bpmn:incoming>Flow_CA1</bpmn:incoming>
      <bpmn:outgoing>Flow_CA2</bpmn:outgoing>
    </bpmn:task>
    <bpmn:endEvent id="Event_CA_QualityRestored" name="Quality auto-upgraded">
      <bpmn:incoming>Flow_CA_BWRestored</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:exclusiveGateway id="Gateway_BandwidthOK" name="Bandwidth Sufficient?">
      <bpmn:incoming>Flow_CA_BWCheck</bpmn:incoming>
      <bpmn:outgoing>Flow_CA_BWYes</bpmn:outgoing>
      <bpmn:outgoing>Flow_CA_BWNo</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:endEvent id="Event_CA_FullQuality" name="Streaming at full quality">
      <bpmn:incoming>Flow_CA_BWYes</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:endEvent id="Event_CA_LowQuality" name="Streaming at reduced quality">
      <bpmn:incoming>Flow_CA_BWStillLow</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:exclusiveGateway id="Gateway_BWRestored" name="Bandwidth Improved?">
      <bpmn:incoming>Flow_CA_MonitorBW</bpmn:incoming>
      <bpmn:outgoing>Flow_CA_BWRestored</bpmn:outgoing>
      <bpmn:outgoing>Flow_CA_BWStillLow</bpmn:outgoing>
    </bpmn:exclusiveGateway>
  </bpmn:process>
  <bpmn:process id="Process_APIGateway" isExecutable="false">
    <bpmn:task id="Activity_ReceiveVideoRequest" name="Receive Request">
      <bpmn:outgoing>Flow_AG1</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Activity_AuthenticateUser" name="Authenticate User">
      <bpmn:incoming>Flow_AG1</bpmn:incoming>
      <bpmn:outgoing>Flow_AG2</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Activity_RouteToVideo" name="Route to Video Service">
      <bpmn:incoming>Flow_AG2</bpmn:incoming>
      <bpmn:outgoing>Flow_AG3</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Activity_ReceiveURL" name="Receive URL">
      <bpmn:incoming>Flow_AG3</bpmn:incoming>
      <bpmn:outgoing>Flow_AG4</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Activity_ForwardURL" name="Forward URL">
      <bpmn:incoming>Flow_AG4</bpmn:incoming>
    </bpmn:task>
    <bpmn:sequenceFlow id="Flow_AG1" sourceRef="Activity_ReceiveVideoRequest" targetRef="Activity_AuthenticateUser" />
    <bpmn:sequenceFlow id="Flow_AG2" sourceRef="Activity_AuthenticateUser" targetRef="Activity_RouteToVideo" />
    <bpmn:sequenceFlow id="Flow_AG3" sourceRef="Activity_RouteToVideo" targetRef="Activity_ReceiveURL" />
    <bpmn:sequenceFlow id="Flow_AG4" sourceRef="Activity_ReceiveURL" targetRef="Activity_ForwardURL" />
  </bpmn:process>
  <bpmn:process id="Process_VideoService" isExecutable="false">
    <bpmn:task id="Activity_ReceiveRequest" name="Receive Request">
      <bpmn:outgoing>Flow_VS1</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Activity_ValidateParams" name="Validate Parameters">
      <bpmn:incoming>Flow_VS1</bpmn:incoming>
      <bpmn:outgoing>Flow_VS2</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Activity_QueryArchive" name="Query Archive">
      <bpmn:incoming>Flow_VS2</bpmn:incoming>
      <bpmn:outgoing>Flow_VS3</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Activity_ReceiveFiles" name="Receive Files">
      <bpmn:incoming>Flow_VS3</bpmn:incoming>
      <bpmn:outgoing>Flow_VS4</bpmn:outgoing>
    </bpmn:task>
    <bpmn:exclusiveGateway id="Gateway_Found" name="Video Found?">
      <bpmn:incoming>Flow_VS4</bpmn:incoming>
      <bpmn:outgoing>Flow_VS5_Yes</bpmn:outgoing>
      <bpmn:outgoing>Flow_VS5_No</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:task id="Activity_GenerateManifest" name="Generate Manifest">
      <bpmn:incoming>Flow_VS5_Yes</bpmn:incoming>
      <bpmn:outgoing>Flow_VS6</bpmn:outgoing>
    </bpmn:task>
    <bpmn:endEvent id="Event_NotFound" name="Error: Not Found">
      <bpmn:incoming>Flow_VS5_No</bpmn:incoming>
      <bpmn:errorEventDefinition id="ErrorDef_NotFound" />
    </bpmn:endEvent>
    <bpmn:task id="Activity_GenerateURLs" name="Generate Signed URLs">
      <bpmn:incoming>Flow_VS6</bpmn:incoming>
      <bpmn:outgoing>Flow_VS7</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Activity_ReturnStreamURL" name="Return Stream URL">
      <bpmn:incoming>Flow_VS7</bpmn:incoming>
    </bpmn:task>
    <bpmn:sequenceFlow id="Flow_VS1" sourceRef="Activity_ReceiveRequest" targetRef="Activity_ValidateParams" />
    <bpmn:sequenceFlow id="Flow_VS2" sourceRef="Activity_ValidateParams" targetRef="Activity_QueryArchive" />
    <bpmn:sequenceFlow id="Flow_VS3" sourceRef="Activity_QueryArchive" targetRef="Activity_ReceiveFiles" />
    <bpmn:sequenceFlow id="Flow_VS4" sourceRef="Activity_ReceiveFiles" targetRef="Gateway_Found" />
    <bpmn:sequenceFlow id="Flow_VS5_Yes" name="Yes" sourceRef="Gateway_Found" targetRef="Activity_GenerateManifest" />
    <bpmn:sequenceFlow id="Flow_VS5_No" name="No" sourceRef="Gateway_Found" targetRef="Event_NotFound" />
    <bpmn:sequenceFlow id="Flow_VS6" sourceRef="Activity_GenerateManifest" targetRef="Activity_GenerateURLs" />
    <bpmn:sequenceFlow id="Flow_VS7" sourceRef="Activity_GenerateURLs" targetRef="Activity_ReturnStreamURL" />
  </bpmn:process>
  <bpmn:process id="Process_DataStorage" isExecutable="false">
    <bpmn:task id="Activity_FindVideos" name="Query Video Archive">
      <bpmn:outgoing>Flow_DS1</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Activity_ReturnFiles" name="Return File Keys">
      <bpmn:incoming>Flow_DS1</bpmn:incoming>
    </bpmn:task>
    <bpmn:task id="Activity_StreamChunks" name="Receive Chunk Request">
      <bpmn:outgoing>Flow_DS2</bpmn:outgoing>
    </bpmn:task>
    <bpmn:exclusiveGateway id="Gateway_DS_BW" name="Bandwidth Sufficient?">
      <bpmn:incoming>Flow_DS2</bpmn:incoming>
      <bpmn:outgoing>Flow_DS_BWYes</bpmn:outgoing>
      <bpmn:outgoing>Flow_DS_BWNo</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:task id="Activity_DeliverChunks" name="Stream Chunks (HD)">
      <bpmn:incoming>Flow_DS_BWYes</bpmn:incoming>
    </bpmn:task>
    <bpmn:task id="Activity_ReduceBitrate" name="Transcode to Lower Bitrate">
      <bpmn:incoming>Flow_DS_BWNo</bpmn:incoming>
      <bpmn:outgoing>Flow_DS_LowQ</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Activity_DeliverLowQualityChunks" name="Stream Chunks (Low Resolution)">
      <bpmn:incoming>Flow_DS_LowQ</bpmn:incoming>
      <bpmn:outgoing>Flow_DS_Monitor</bpmn:outgoing>
    </bpmn:task>
    <bpmn:exclusiveGateway id="Gateway_DS_BWRestored" name="Bandwidth Recovered?">
      <bpmn:incoming>Flow_DS_Monitor</bpmn:incoming>
      <bpmn:outgoing>Flow_DS_Recovered</bpmn:outgoing>
      <bpmn:outgoing>Flow_DS_StillLow</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:task id="Activity_RestoreHDQuality" name="Restore HD Streaming">
      <bpmn:incoming>Flow_DS_Recovered</bpmn:incoming>
    </bpmn:task>
    <bpmn:endEvent id="Event_DS_StillLow" name="Continue reduced quality">
      <bpmn:incoming>Flow_DS_StillLow</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="Flow_DS1" sourceRef="Activity_FindVideos" targetRef="Activity_ReturnFiles" />
    <bpmn:sequenceFlow id="Flow_DS2" sourceRef="Activity_StreamChunks" targetRef="Gateway_DS_BW" />
    <bpmn:sequenceFlow id="Flow_DS_BWYes" name="Yes" sourceRef="Gateway_DS_BW" targetRef="Activity_DeliverChunks" />
    <bpmn:sequenceFlow id="Flow_DS_BWNo" name="No" sourceRef="Gateway_DS_BW" targetRef="Activity_ReduceBitrate" />
    <bpmn:sequenceFlow id="Flow_DS_LowQ" sourceRef="Activity_ReduceBitrate" targetRef="Activity_DeliverLowQualityChunks" />
    <bpmn:sequenceFlow id="Flow_DS_Monitor" sourceRef="Activity_DeliverLowQualityChunks" targetRef="Gateway_DS_BWRestored" />
    <bpmn:sequenceFlow id="Flow_DS_Recovered" name="Yes" sourceRef="Gateway_DS_BWRestored" targetRef="Activity_RestoreHDQuality" />
    <bpmn:sequenceFlow id="Flow_DS_StillLow" name="No" sourceRef="Gateway_DS_BWRestored" targetRef="Event_DS_StillLow" />
  </bpmn:process>
  <bpmndi:BPMNDiagram id="BPMNDiagram_1">
    <bpmndi:BPMNPlane id="BPMNPlane_1" bpmnElement="Collaboration_VideoPlayback">
      <bpmndi:BPMNShape id="Participant_Homeowner_di" bpmnElement="Participant_Homeowner" isHorizontal="true">
        <dc:Bounds x="160" y="140" width="1300" height="140" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Event_Start_di" bpmnElement="Event_Start">
        <dc:Bounds x="222" y="192" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="204" y="235" width="72" height="27" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Activity_OpenApp_di" bpmnElement="Activity_OpenApp">
        <dc:Bounds x="320" y="170" width="140" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Activity_SelectCamera_di" bpmnElement="Activity_SelectCamera">
        <dc:Bounds x="520" y="170" width="140" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Activity_NavigateHistory_di" bpmnElement="Activity_NavigateHistory">
        <dc:Bounds x="720" y="170" width="160" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Activity_SelectTimeRange_di" bpmnElement="Activity_SelectTimeRange">
        <dc:Bounds x="940" y="170" width="160" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Activity_WatchVideo_di" bpmnElement="Activity_WatchVideo">
        <dc:Bounds x="1160" y="170" width="140" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Event_End_di" bpmnElement="Event_End">
        <dc:Bounds x="1362" y="192" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="1336" y="235" width="88" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNEdge id="Flow_H1_di" bpmnElement="Flow_H1">
        <di:waypoint x="258" y="210" />
        <di:waypoint x="320" y="210" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_H2_di" bpmnElement="Flow_H2">
        <di:waypoint x="460" y="210" />
        <di:waypoint x="520" y="210" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_H3_di" bpmnElement="Flow_H3">
        <di:waypoint x="660" y="210" />
        <di:waypoint x="720" y="210" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_H4_di" bpmnElement="Flow_H4">
        <di:waypoint x="880" y="210" />
        <di:waypoint x="940" y="210" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_H5_di" bpmnElement="Flow_H5">
        <di:waypoint x="1100" y="210" />
        <di:waypoint x="1160" y="210" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_H6_di" bpmnElement="Flow_H6">
        <di:waypoint x="1300" y="210" />
        <di:waypoint x="1362" y="210" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNShape id="Participant_ClientApp_di" bpmnElement="Participant_ClientApp" isHorizontal="true">
        <dc:Bounds x="160" y="300" width="1600" height="440" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Activity_ReceiveSelection_di" bpmnElement="Activity_ReceiveSelection">
        <dc:Bounds x="240" y="330" width="140" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Activity_ShowLoading_di" bpmnElement="Activity_ShowLoading">
        <dc:Bounds x="440" y="330" width="120" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Activity_RequestVideo_di" bpmnElement="Activity_RequestVideo">
        <dc:Bounds x="620" y="330" width="130" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Activity_ReceiveStreamURL_di" bpmnElement="Activity_ReceiveStreamURL">
        <dc:Bounds x="810" y="330" width="150" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Activity_InitPlayer_di" bpmnElement="Activity_InitPlayer">
        <dc:Bounds x="1020" y="330" width="130" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Activity_RequestChunks_di" bpmnElement="Activity_RequestChunks">
        <dc:Bounds x="1210" y="330" width="130" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Activity_ReceiveChunks_di" bpmnElement="Activity_ReceiveChunks">
        <dc:Bounds x="1400" y="330" width="130" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Activity_RenderVideo_di" bpmnElement="Activity_RenderVideo">
        <dc:Bounds x="1590" y="330" width="120" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Activity_ShowReducedQuality_di" bpmnElement="Activity_ShowReducedQuality">
        <dc:Bounds x="1560" y="530" width="180" height="70" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Event_CA_QualityRestored_di" bpmnElement="Event_CA_QualityRestored">
        <dc:Bounds x="1712" y="647" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="1699" y="690" width="63" height="27" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Gateway_BandwidthOK_di" bpmnElement="Gateway_BandwidthOK" isMarkerVisible="true">
        <dc:Bounds x="1525" y="455" width="50" height="50" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="1524" y="426" width="52" height="27" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Event_CA_FullQuality_di" bpmnElement="Event_CA_FullQuality">
