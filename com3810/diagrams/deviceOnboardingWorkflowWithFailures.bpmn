<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" xmlns:modeler="http://camunda.org/schema/modeler/1.0" id="Definitions_DeviceOnboardingV2" targetNamespace="http://bpmn.io/schema/bpmn" exporter="Camunda Modeler" exporterVersion="5.44.0" modeler:executionPlatform="Camunda Cloud" modeler:executionPlatformVersion="8.8.0">
  <bpmn:collaboration id="Collaboration_DeviceOnboarding">
    <bpmn:participant id="Participant_Homeowner" name="Homeowner" processRef="Process_Homeowner" />
    <bpmn:participant id="Participant_ClientApp" name="Client Application" processRef="Process_ClientApp" />
    <bpmn:participant id="Participant_APIGateway" name="API Gateway" processRef="Process_APIGateway" />
    <bpmn:participant id="Participant_UserMgmt" name="User Management Service" processRef="Process_UserMgmt" />
    <bpmn:participant id="Participant_DeviceMgmt" name="Device Management Service" processRef="Process_DeviceMgmt" />
    <bpmn:participant id="Participant_IoTFirmware" name="IoT Device Firmware" processRef="Process_IoTFirmware" />
    <bpmn:participant id="Participant_DataStorage" name="Data Storage Layer" processRef="Process_DataStorage" />
    <bpmn:messageFlow id="Flow_HomeownerToApp" sourceRef="Activity_DownloadApp" targetRef="Activity_AppLaunches" />
    <bpmn:messageFlow id="Flow_HomeownerScanToApp" sourceRef="Activity_ScanQR" targetRef="Activity_ValidateQR" />
    <bpmn:messageFlow id="Flow_HomeownerManualToApp" sourceRef="Activity_EnterManualID" targetRef="Activity_ValidateManualID" />
    <bpmn:messageFlow id="Flow_AppToHomeowner_ClickAdd" sourceRef="Activity_PromptScan" targetRef="Activity_ScanQR" />
    <bpmn:messageFlow id="Flow_AppToHomeowner_Guide" sourceRef="Activity_GuideWiFi" targetRef="Activity_ConnectWifi" />
    <bpmn:messageFlow id="Flow_AppToHomeowner_Troubleshoot" sourceRef="Activity_ShowTroubleshoot" targetRef="Activity_RetryWifi" />
    <bpmn:messageFlow id="Flow_HomeownerRetryWifi" sourceRef="Activity_RetryWifi" targetRef="Activity_WiFiConnectedCheck" />
    <bpmn:messageFlow id="Flow_AppToGateway" sourceRef="Activity_SendRegistration" targetRef="Activity_ReceiveRequest" />
    <bpmn:messageFlow id="Flow_GatewayToApp" sourceRef="Activity_ForwardToClient" targetRef="Activity_ReceiveDeviceIDApp" />
    <bpmn:messageFlow id="Flow_GatewayToUserMgmt" sourceRef="Activity_AuthenticateUser" targetRef="Activity_ValidateToken" />
    <bpmn:messageFlow id="Flow_UserMgmtToGateway" sourceRef="Activity_ReturnAuthResult" targetRef="Activity_ReceiveAuthResult" />
    <bpmn:messageFlow id="Flow_GatewayToDeviceMgmt" sourceRef="Activity_RouteToDeviceMgmt" targetRef="Activity_CreateDevice" />
    <bpmn:messageFlow id="Flow_DeviceMgmtToGateway" sourceRef="Activity_ReturnSuccess" targetRef="Activity_ReceiveSuccess" />
    <bpmn:messageFlow id="Flow_DeviceMgmtToStorage1" sourceRef="Activity_StoreDevice" targetRef="Activity_PersistDevice" />
    <bpmn:messageFlow id="Flow_StorageToDeviceMgmt" sourceRef="Activity_ReturnDeviceID" targetRef="Activity_ReceiveDeviceID" />
    <bpmn:messageFlow id="Flow_DeviceMgmtToStorage2" sourceRef="Activity_MarkOnline" targetRef="Activity_UpdateStatus" />
    <bpmn:messageFlow id="Flow_DeviceMgmtRequestFirmware" sourceRef="Activity_RequestFirmware" targetRef="Activity_GetLatestFirmware" />
    <bpmn:messageFlow id="Flow_StorageSendFirmware" sourceRef="Activity_SendLatestFirmware" targetRef="Activity_SendFirmwareToDevice" />
    <bpmn:messageFlow id="Flow_FirmwareToDeviceMgmt" sourceRef="Activity_RegisterWithDMS" targetRef="Activity_AcceptRegistration" />
    <bpmn:messageFlow id="Flow_DeviceMgmtToFirmware" sourceRef="Activity_SendCredentials" targetRef="Activity_ReceiveCredentials" />
    <bpmn:messageFlow id="Flow_DeviceMgmtFirmwareToDevice" sourceRef="Activity_SendFirmwareToDevice" targetRef="Activity_DownloadFirmware" />
    <bpmn:messageFlow id="Flow_FirmwareToApp" sourceRef="Activity_ConfirmOnline" targetRef="Activity_DisplayDashboard" />
    <bpmn:messageFlow id="Flow_0r9dcqt" sourceRef="Activity_ConnectWifi" targetRef="Activity_ConnectToWifi" />
    <bpmn:messageFlow id="Flow_0icu0vs" sourceRef="Activity_ConnectToDMS" targetRef="Activity_RequestFirmware" />
    <bpmn:messageFlow id="Flow_1h9yaf3" sourceRef="Activity_ValidateUserDB" targetRef="Activity_ValidateToken" />
    <bpmn:textAnnotation id="TextAnnotation_Title">
      <bpmn:text>Device Onboarding Workflow (with Failure Scenarios)</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:association id="Association_Title" sourceRef="Participant_Homeowner" targetRef="TextAnnotation_Title" />
  </bpmn:collaboration>
  <bpmn:process id="Process_Homeowner" isExecutable="false">
    <bpmn:startEvent id="Event_Start" name="Homeowner purchases device">
      <bpmn:outgoing>Flow_H1</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:task id="Activity_DownloadApp" name="Open Client App">
      <bpmn:incoming>Flow_H1</bpmn:incoming>
      <bpmn:outgoing>Flow_H2</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Activity_CreateAccount" name="Click add device">
      <bpmn:incoming>Flow_H2</bpmn:incoming>
      <bpmn:outgoing>Flow_H3</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Activity_ScanQR" name="Scan Device QR Code">
      <bpmn:incoming>Flow_H3</bpmn:incoming>
      <bpmn:outgoing>Flow_H4a</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Activity_EnterManualID" name="Enter Device ID Manually">
      <bpmn:incoming>Flow_H_ManualPrompt</bpmn:incoming>
      <bpmn:outgoing>Flow_H_ManualSend</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Activity_ConnectWifi" name="Connect Device to WiFi">
      <bpmn:incoming>Flow_H4a</bpmn:incoming>
      <bpmn:incoming>Flow_H_ManualSend</bpmn:incoming>
      <bpmn:outgoing>Flow_0jg6ujk</bpmn:outgoing>
    </bpmn:task>
    <bpmn:exclusiveGateway id="Gateway_0y4bkid" name="WiFi Connected?">
      <bpmn:incoming>Flow_0jg6ujk</bpmn:incoming>
      <bpmn:outgoing>Flow_H5</bpmn:outgoing>
      <bpmn:outgoing>Flow_H_Troubleshoot</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:task id="Activity_RetryWifi" name="Retry WiFi with Correct Password">
      <bpmn:incoming>Flow_H_Troubleshoot</bpmn:incoming>
      <bpmn:outgoing>Flow_H_RetryLoop</bpmn:outgoing>
    </bpmn:task>
    <bpmn:endEvent id="Event_End" name="Device appears in dashboard">
      <bpmn:incoming>Flow_H5</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="Flow_H1" sourceRef="Event_Start" targetRef="Activity_DownloadApp" />
    <bpmn:sequenceFlow id="Flow_H2" sourceRef="Activity_DownloadApp" targetRef="Activity_CreateAccount" />
    <bpmn:sequenceFlow id="Flow_H3" sourceRef="Activity_CreateAccount" targetRef="Activity_ScanQR" />
    <bpmn:sequenceFlow id="Flow_H4a" sourceRef="Activity_ScanQR" targetRef="Activity_ConnectWifi" />
    <bpmn:sequenceFlow id="Flow_H_ManualPrompt" sourceRef="Activity_ScanQR" targetRef="Activity_EnterManualID" />
    <bpmn:sequenceFlow id="Flow_H_ManualSend" sourceRef="Activity_EnterManualID" targetRef="Activity_ConnectWifi" />
    <bpmn:sequenceFlow id="Flow_0jg6ujk" sourceRef="Activity_ConnectWifi" targetRef="Gateway_0y4bkid" />
    <bpmn:sequenceFlow id="Flow_H5" name="Connected" sourceRef="Gateway_0y4bkid" targetRef="Event_End" />
    <bpmn:sequenceFlow id="Flow_H_Troubleshoot" name="Not Connected" sourceRef="Gateway_0y4bkid" targetRef="Activity_RetryWifi" />
    <bpmn:sequenceFlow id="Flow_H_RetryLoop" sourceRef="Activity_RetryWifi" targetRef="Activity_ConnectWifi" />
  </bpmn:process>
  <bpmn:process id="Process_ClientApp" isExecutable="false">
    <bpmn:task id="Activity_AppLaunches" name="App Launches">
      <bpmn:outgoing>Flow_CA0</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Activity_PromptScan" name="Prompt User to Scan QR">
      <bpmn:incoming>Flow_CA0</bpmn:incoming>
      <bpmn:outgoing>Flow_CA1</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Activity_ValidateQR" name="Validate QR Code Format">
      <bpmn:incoming>Flow_CA1</bpmn:incoming>
      <bpmn:outgoing>Flow_CA_QRGateway</bpmn:outgoing>
    </bpmn:task>
    <bpmn:exclusiveGateway id="Gateway_QRValid" name="QR Code Valid?">
      <bpmn:incoming>Flow_CA_QRGateway</bpmn:incoming>
      <bpmn:outgoing>Flow_CA_QRYes</bpmn:outgoing>
      <bpmn:outgoing>Flow_CA_QRNo</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:task id="Activity_ShowQRError" name="Show QR Error, Offer Manual Entry">
      <bpmn:incoming>Flow_CA_QRNo</bpmn:incoming>
      <bpmn:outgoing>Flow_CA_ManualEntry</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Activity_ValidateManualID" name="Validate Manual Device ID">
      <bpmn:incoming>Flow_CA_ManualEntry</bpmn:incoming>
      <bpmn:outgoing>Flow_CA_ManualGateway</bpmn:outgoing>
    </bpmn:task>
    <bpmn:exclusiveGateway id="Gateway_ManualIDValid" name="Manual ID Valid?">
      <bpmn:incoming>Flow_CA_ManualGateway</bpmn:incoming>
      <bpmn:outgoing>Flow_CA_ManualYes</bpmn:outgoing>
      <bpmn:outgoing>Flow_CA_ManualNo</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:endEvent id="Event_CA_InvalidID" name="Error: Invalid Device ID">
      <bpmn:incoming>Flow_CA_ManualNo</bpmn:incoming>
      <bpmn:errorEventDefinition id="ErrorDef_InvalidID" />
    </bpmn:endEvent>
    <bpmn:task id="Activity_SendRegistration" name="Send Device Registration Request">
      <bpmn:incoming>Flow_CA_QRYes</bpmn:incoming>
      <bpmn:incoming>Flow_CA_ManualYes</bpmn:incoming>
      <bpmn:outgoing>Flow_CA4</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Activity_ReceiveDeviceIDApp" name="Receive Device ID">
      <bpmn:incoming>Flow_CA4</bpmn:incoming>
      <bpmn:outgoing>Flow_CA5</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Activity_GuideWiFi" name="Guide User Through WiFi Setup">
      <bpmn:incoming>Flow_CA5</bpmn:incoming>
      <bpmn:outgoing>Flow_CA_WifiCheck</bpmn:outgoing>
    </bpmn:task>
    <bpmn:exclusiveGateway id="Gateway_WiFiConnected" name="WiFi Connected?">
      <bpmn:incoming>Flow_CA_WifiCheck</bpmn:incoming>
      <bpmn:incoming>Flow_CA_BackToGateway</bpmn:incoming>
      <bpmn:outgoing>Flow_CA_WifiYes</bpmn:outgoing>
      <bpmn:outgoing>Flow_CA_WifiNo</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:task id="Activity_WiFiConnectedCheck" name="Receive WiFi Retry">
      <bpmn:incoming>Flow_CA_WiFiRetry</bpmn:incoming>
      <bpmn:outgoing>Flow_CA_BackToGateway</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Activity_DisplayDashboard" name="Display Device in Dashboard">
      <bpmn:incoming>Flow_CA_WifiYes</bpmn:incoming>
    </bpmn:task>
    <bpmn:sequenceFlow id="Flow_CA0" sourceRef="Activity_AppLaunches" targetRef="Activity_PromptScan" />
    <bpmn:sequenceFlow id="Flow_CA1" sourceRef="Activity_PromptScan" targetRef="Activity_ValidateQR" />
    <bpmn:sequenceFlow id="Flow_CA_QRGateway" sourceRef="Activity_ValidateQR" targetRef="Gateway_QRValid" />
    <bpmn:sequenceFlow id="Flow_CA_QRYes" name="Valid" sourceRef="Gateway_QRValid" targetRef="Activity_SendRegistration" />
    <bpmn:sequenceFlow id="Flow_CA_QRNo" name="Invalid" sourceRef="Gateway_QRValid" targetRef="Activity_ShowQRError" />
    <bpmn:sequenceFlow id="Flow_CA_ManualEntry" sourceRef="Activity_ShowQRError" targetRef="Activity_ValidateManualID" />
    <bpmn:sequenceFlow id="Flow_CA_ManualGateway" sourceRef="Activity_ValidateManualID" targetRef="Gateway_ManualIDValid" />
    <bpmn:sequenceFlow id="Flow_CA_ManualYes" name="Valid" sourceRef="Gateway_ManualIDValid" targetRef="Activity_SendRegistration" />
    <bpmn:sequenceFlow id="Flow_CA_ManualNo" name="Invalid" sourceRef="Gateway_ManualIDValid" targetRef="Event_CA_InvalidID" />
    <bpmn:sequenceFlow id="Flow_CA4" sourceRef="Activity_SendRegistration" targetRef="Activity_ReceiveDeviceIDApp" />
    <bpmn:sequenceFlow id="Flow_CA5" sourceRef="Activity_ReceiveDeviceIDApp" targetRef="Activity_GuideWiFi" />
    <bpmn:sequenceFlow id="Flow_CA_WifiCheck" sourceRef="Activity_GuideWiFi" targetRef="Gateway_WiFiConnected" />
    <bpmn:sequenceFlow id="Flow_CA_WifiYes" name="Connected" sourceRef="Gateway_WiFiConnected" targetRef="Activity_DisplayDashboard" />
    <bpmn:sequenceFlow id="Flow_CA_WifiNo" name="Not Connected" sourceRef="Gateway_WiFiConnected" targetRef="Activity_ShowTroubleshoot" />
    <bpmn:sequenceFlow id="Flow_CA_WiFiRetry" sourceRef="Activity_ShowTroubleshoot" targetRef="Activity_WiFiConnectedCheck" />
    <bpmn:sequenceFlow id="Flow_CA_BackToGateway" sourceRef="Activity_WiFiConnectedCheck" targetRef="Gateway_WiFiConnected" />
    <bpmn:task id="Activity_ShowTroubleshoot" name="Show WiFi Troubleshooting Steps">
      <bpmn:incoming>Flow_CA_WifiNo</bpmn:incoming>
      <bpmn:outgoing>Flow_CA_WiFiRetry</bpmn:outgoing>
    </bpmn:task>
  </bpmn:process>
  <bpmn:process id="Process_APIGateway" isExecutable="false">
    <bpmn:task id="Activity_ReceiveRequest" name="Receive Registration Request">
      <bpmn:outgoing>Flow_AG1</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Activity_AuthenticateUser" name="Authenticate User">
      <bpmn:incoming>Flow_AG1</bpmn:incoming>
      <bpmn:outgoing>Flow_AG2</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Activity_ReceiveAuthResult" name="Receive Auth Result">
      <bpmn:incoming>Flow_AG2</bpmn:incoming>
      <bpmn:outgoing>Flow_AG_AuthGateway</bpmn:outgoing>
    </bpmn:task>
    <bpmn:exclusiveGateway id="Gateway_AuthSuccess" name="Auth Successful?">
      <bpmn:incoming>Flow_AG_AuthGateway</bpmn:incoming>
      <bpmn:outgoing>Flow_AG_AuthYes</bpmn:outgoing>
      <bpmn:outgoing>Flow_AG_AuthNo</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:endEvent id="Event_AG_AuthFailed" name="Error: Auth Failed">
      <bpmn:incoming>Flow_AG_AuthNo</bpmn:incoming>
      <bpmn:errorEventDefinition id="ErrorDef_AuthFailed" />
    </bpmn:endEvent>
    <bpmn:task id="Activity_RouteToDeviceMgmt" name="Route to Device Management">
      <bpmn:incoming>Flow_AG_AuthYes</bpmn:incoming>
      <bpmn:outgoing>Flow_AG4</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Activity_ReceiveSuccess" name="Receive Success Response">
      <bpmn:incoming>Flow_AG4</bpmn:incoming>
      <bpmn:outgoing>Flow_AG5</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Activity_ForwardToClient" name="Forward Response to Client">
      <bpmn:incoming>Flow_AG5</bpmn:incoming>
    </bpmn:task>
    <bpmn:sequenceFlow id="Flow_AG1" sourceRef="Activity_ReceiveRequest" targetRef="Activity_AuthenticateUser" />
    <bpmn:sequenceFlow id="Flow_AG2" sourceRef="Activity_AuthenticateUser" targetRef="Activity_ReceiveAuthResult" />
    <bpmn:sequenceFlow id="Flow_AG_AuthGateway" sourceRef="Activity_ReceiveAuthResult" targetRef="Gateway_AuthSuccess" />
    <bpmn:sequenceFlow id="Flow_AG_AuthYes" name="Yes" sourceRef="Gateway_AuthSuccess" targetRef="Activity_RouteToDeviceMgmt" />
    <bpmn:sequenceFlow id="Flow_AG_AuthNo" name="No" sourceRef="Gateway_AuthSuccess" targetRef="Event_AG_AuthFailed" />
    <bpmn:sequenceFlow id="Flow_AG4" sourceRef="Activity_RouteToDeviceMgmt" targetRef="Activity_ReceiveSuccess" />
    <bpmn:sequenceFlow id="Flow_AG5" sourceRef="Activity_ReceiveSuccess" targetRef="Activity_ForwardToClient" />
  </bpmn:process>
  <bpmn:process id="Process_UserMgmt" isExecutable="false">
    <bpmn:task id="Activity_ValidateToken" name="Validate Auth Token">
      <bpmn:outgoing>Flow_UM1</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Activity_ReturnAuthResult" name="Return Auth Result">
      <bpmn:incoming>Flow_UM1</bpmn:incoming>
    </bpmn:task>
    <bpmn:sequenceFlow id="Flow_UM1" sourceRef="Activity_ValidateToken" targetRef="Activity_ReturnAuthResult" />
  </bpmn:process>
  <bpmn:process id="Process_DeviceMgmt" isExecutable="false">
    <bpmn:task id="Activity_CreateDevice" name="Create Device Record">
      <bpmn:outgoing>Flow_DM_DupCheck</bpmn:outgoing>
    </bpmn:task>
    <bpmn:exclusiveGateway id="Gateway_AlreadyRegistered" name="Device Already Registered?">
      <bpmn:incoming>Flow_DM_DupCheck</bpmn:incoming>
      <bpmn:outgoing>Flow_DM_DupNo</bpmn:outgoing>
      <bpmn:outgoing>Flow_DM_DupYes</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:endEvent id="Event_DM_AlreadyRegistered" name="Error: Already Registered">
      <bpmn:incoming>Flow_DM_DupYes</bpmn:incoming>
      <bpmn:errorEventDefinition id="ErrorDef_AlreadyRegistered" />
    </bpmn:endEvent>
    <bpmn:task id="Activity_GenerateCredentials" name="Generate Credentials">
      <bpmn:incoming>Flow_DM_DupNo</bpmn:incoming>
      <bpmn:outgoing>Flow_DM2</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Activity_StoreDevice" name="Store Device in DB">
      <bpmn:incoming>Flow_DM2</bpmn:incoming>
      <bpmn:outgoing>Flow_DM3</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Activity_ReceiveDeviceID" name="Receive Device ID">
      <bpmn:incoming>Flow_DM3</bpmn:incoming>
      <bpmn:outgoing>Flow_DM4</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Activity_ReturnSuccess" name="Return Device ID to Gateway">
      <bpmn:incoming>Flow_DM4</bpmn:incoming>
    </bpmn:task>
    <bpmn:task id="Activity_AcceptRegistration" name="Accept Device Registration">
      <bpmn:outgoing>Flow_DM5</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Activity_SendCredentials" name="Send Connection Credentials">
      <bpmn:incoming>Flow_DM5</bpmn:incoming>
      <bpmn:outgoing>Flow_DM6</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Activity_MarkOnline" name="Mark Device as Online">
      <bpmn:incoming>Flow_DM6</bpmn:incoming>
    </bpmn:task>
    <bpmn:task id="Activity_RequestFirmware" name="Request Latest Firmware">
      <bpmn:outgoing>Flow_DM8</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Activity_SendFirmwareToDevice" name="Send Firmware to Device">
      <bpmn:incoming>Flow_DM8</bpmn:incoming>
    </bpmn:task>
    <bpmn:sequenceFlow id="Flow_DM_DupCheck" sourceRef="Activity_CreateDevice" targetRef="Gateway_AlreadyRegistered" />
    <bpmn:sequenceFlow id="Flow_DM_DupNo" name="No" sourceRef="Gateway_AlreadyRegistered" targetRef="Activity_GenerateCredentials" />
    <bpmn:sequenceFlow id="Flow_DM_DupYes" name="Yes" sourceRef="Gateway_AlreadyRegistered" targetRef="Event_DM_AlreadyRegistered" />
    <bpmn:sequenceFlow id="Flow_DM2" sourceRef="Activity_GenerateCredentials" targetRef="Activity_StoreDevice" />
    <bpmn:sequenceFlow id="Flow_DM3" sourceRef="Activity_StoreDevice" targetRef="Activity_ReceiveDeviceID" />
    <bpmn:sequenceFlow id="Flow_DM4" sourceRef="Activity_ReceiveDeviceID" targetRef="Activity_ReturnSuccess" />
    <bpmn:sequenceFlow id="Flow_DM5" sourceRef="Activity_AcceptRegistration" targetRef="Activity_SendCredentials" />
    <bpmn:sequenceFlow id="Flow_DM6" sourceRef="Activity_SendCredentials" targetRef="Activity_MarkOnline" />
    <bpmn:sequenceFlow id="Flow_DM8" sourceRef="Activity_RequestFirmware" targetRef="Activity_SendFirmwareToDevice" />
  </bpmn:process>
  <bpmn:process id="Process_IoTFirmware" isExecutable="false">
    <bpmn:task id="Activity_PowerOn" name="Power On">
      <bpmn:outgoing>Flow_IOT0</bpmn:outgoing>
    </bpmn:task>
    <bpmn:exclusiveGateway id="Gateway_FirmwareWifi" name="WiFi Connected?">
      <bpmn:incoming>Flow_IOT_WifiGateway</bpmn:incoming>
      <bpmn:incoming>Flow_IOT_BackoffRetry</bpmn:incoming>
      <bpmn:outgoing>Flow_IOT_WifiYes</bpmn:outgoing>
      <bpmn:outgoing>Flow_IOT_WifiNo</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:task id="Activity_ExponentialBackoff" name="Wait (Exponential Backoff)">
      <bpmn:incoming>Flow_IOT_WifiNo</bpmn:incoming>
      <bpmn:outgoing>Flow_IOT_BackoffRetry</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Activity_ReceiveCredentials" name="Receive Credentials">
      <bpmn:incoming>Flow_IOT2</bpmn:incoming>
      <bpmn:outgoing>Flow_IOT3</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Activity_ConnectToDMS" name="Connect to DMS">
      <bpmn:incoming>Flow_IOT3</bpmn:incoming>
      <bpmn:outgoing>Flow_IOT4</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Activity_DownloadFirmware" name="Download Latest Firmware">
      <bpmn:incoming>Flow_IOT4</bpmn:incoming>
      <bpmn:outgoing>Flow_IOT5</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Activity_ConfirmOnline" name="Confirm Online Status">
      <bpmn:incoming>Flow_IOT5</bpmn:incoming>
      <bpmn:outgoing>Flow_IOT6</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Activity_BeginOperation" name="Begin Normal Operation">
      <bpmn:incoming>Flow_IOT6</bpmn:incoming>
    </bpmn:task>
    <bpmn:sequenceFlow id="Flow_IOT0" sourceRef="Activity_PowerOn" targetRef="Activity_ConnectToWifi" />
    <bpmn:sequenceFlow id="Flow_IOT_WifiGateway" sourceRef="Activity_ConnectToWifi" targetRef="Gateway_FirmwareWifi" />
    <bpmn:sequenceFlow id="Flow_IOT_WifiYes" name="Connected" sourceRef="Gateway_FirmwareWifi" targetRef="Activity_RegisterWithDMS" />
    <bpmn:sequenceFlow id="Flow_IOT_WifiNo" name="Not Connected" sourceRef="Gateway_FirmwareWifi" targetRef="Activity_ExponentialBackoff" />
    <bpmn:sequenceFlow id="Flow_IOT_BackoffRetry" sourceRef="Activity_ExponentialBackoff" targetRef="Gateway_FirmwareWifi" />
    <bpmn:sequenceFlow id="Flow_IOT2" sourceRef="Activity_RegisterWithDMS" targetRef="Activity_ReceiveCredentials" />
    <bpmn:sequenceFlow id="Flow_IOT3" sourceRef="Activity_ReceiveCredentials" targetRef="Activity_ConnectToDMS" />
    <bpmn:sequenceFlow id="Flow_IOT4" sourceRef="Activity_ConnectToDMS" targetRef="Activity_DownloadFirmware" />
    <bpmn:sequenceFlow id="Flow_IOT5" sourceRef="Activity_DownloadFirmware" targetRef="Activity_ConfirmOnline" />
    <bpmn:sequenceFlow id="Flow_IOT6" sourceRef="Activity_ConfirmOnline" targetRef="Activity_BeginOperation" />
    <bpmn:task id="Activity_ConnectToWifi" name="Connect to WiFi">
      <bpmn:incoming>Flow_IOT0</bpmn:incoming>
      <bpmn:outgoing>Flow_IOT_WifiGateway</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Activity_RegisterWithDMS" name="Register with DMS">
      <bpmn:incoming>Flow_IOT_WifiYes</bpmn:incoming>
      <bpmn:outgoing>Flow_IOT2</bpmn:outgoing>
    </bpmn:task>
  </bpmn:process>
  <bpmn:process id="Process_DataStorage" isExecutable="false">
    <bpmn:task id="Activity_ValidateUserDB" name="Validate User" />
    <bpmn:task id="Activity_PersistDevice" name="Persist Device Record">
      <bpmn:outgoing>Flow_DS2</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Activity_ReturnDeviceID" name="Return Device ID">
      <bpmn:incoming>Flow_DS2</bpmn:incoming>
    </bpmn:task>
    <bpmn:task id="Activity_GetLatestFirmware" name="Get Latest Firmware">
      <bpmn:outgoing>Flow_DS3</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Activity_SendLatestFirmware" name="Send Latest Firmware">
      <bpmn:incoming>Flow_DS3</bpmn:incoming>
    </bpmn:task>
    <bpmn:sequenceFlow id="Flow_DS2" sourceRef="Activity_PersistDevice" targetRef="Activity_ReturnDeviceID" />
    <bpmn:sequenceFlow id="Flow_DS3" sourceRef="Activity_GetLatestFirmware" targetRef="Activity_SendLatestFirmware" />
    <bpmn:task id="Activity_UpdateStatus" name="Update Device Status to &#39;Online&#39;" />
  </bpmn:process>
