<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" xmlns:modeler="http://camunda.org/schema/modeler/1.0" id="Definitions_MotionAlert" targetNamespace="http://bpmn.io/schema/bpmn" exporter="Camunda Modeler" exporterVersion="5.44.0">
  <bpmn:collaboration id="Collaboration_MotionAlert">
    <bpmn:extensionElements />
    <bpmn:participant id="Participant_PhysicalDevice" name="Physical IoT Device (Motion Sensor)" processRef="Process_PhysicalDevice" />
    <bpmn:participant id="Participant_IoTFirmware" name="IoT Device Management" processRef="Process_IoTFirmware" />
    <bpmn:participant id="Participant_EventProcessing" name="Event Processing Service" processRef="Process_EventProcessing" />
    <bpmn:participant id="Participant_Notification" name="Notification Service" processRef="Process_Notification" />
    <bpmn:participant id="Participant_PushService" name="Push Notification Services (APNs/FCM)" processRef="Process_PushService" />
    <bpmn:participant id="Participant_Homeowner" name="Homeowner" processRef="Process_Homeowner" />
    <bpmn:participant id="Participant_ClientApp" name="Client Application" processRef="Process_ClientApp" />
    <bpmn:participant id="Participant_APIGateway" name="API Gateway" processRef="Process_APIGateway" />
    <bpmn:participant id="Participant_DataStorage" name="Data Storage Layer" processRef="Process_DataStorage" />
    <bpmn:messageFlow id="Flow_DeviceToFirmware" sourceRef="Activity_TriggerInterrupt" targetRef="Activity_CaptureEvent" />
    <bpmn:messageFlow id="Flow_FirmwareToEventProcessing" sourceRef="Activity_SendEventMQTT" targetRef="Activity_IngestEvent" />
    <bpmn:messageFlow id="Flow_EventToStorage" sourceRef="Activity_LogEvent" targetRef="Activity_StoreEvent" />
    <bpmn:messageFlow id="Flow_EventToNotification" sourceRef="Activity_TriggerAlert" targetRef="Activity_ReceiveAlertRequest" />
    <bpmn:messageFlow id="Flow_NotificationToPush" sourceRef="Activity_SendToPushService" targetRef="Activity_ReceiveFromSecureNet" />
    <bpmn:messageFlow id="Flow_PushToHomeowner" sourceRef="Activity_DeliverToMobile" targetRef="Activity_ReceiveNotification" />
    <bpmn:messageFlow id="Flow_HomeownerToApp" sourceRef="Activity_OpenApp" targetRef="Activity_AppOpens" />
    <bpmn:messageFlow id="Flow_AppToGateway" sourceRef="Activity_RequestLiveFeed" targetRef="Activity_ReceiveFeedRequest" />
    <bpmn:messageFlow id="Flow_GatewayToFirmware" sourceRef="Activity_RequestStream" targetRef="Activity_StartStreaming" />
    <bpmn:messageFlow id="Flow_FirmwareToApp" sourceRef="Activity_StreamVideo" targetRef="Activity_DisplayFeed" />
    <bpmn:textAnnotation id="TextAnnotation_Title">
      <bpmn:text>Motion Detection and Alert Workflow</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:association id="Association_Title" sourceRef="Participant_PhysicalDevice" targetRef="TextAnnotation_Title" />
  </bpmn:collaboration>
  <bpmn:process id="Process_PhysicalDevice" isExecutable="false">
    <bpmn:startEvent id="Event_MotionDetected" name="Motion Detected by Sensor">
      <bpmn:outgoing>Flow_PD1</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:task id="Activity_TriggerInterrupt" name="Trigger Hardware Interrupt">
      <bpmn:incoming>Flow_PD1</bpmn:incoming>
    </bpmn:task>
    <bpmn:sequenceFlow id="Flow_PD1" sourceRef="Event_MotionDetected" targetRef="Activity_TriggerInterrupt" />
  </bpmn:process>
  <bpmn:process id="Process_IoTFirmware" isExecutable="false">
    <bpmn:task id="Activity_CaptureEvent" name="Capture Event Details">
      <bpmn:outgoing>Flow_IOT1</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Activity_PackageEvent" name="Package Event Data">
      <bpmn:incoming>Flow_IOT1</bpmn:incoming>
      <bpmn:outgoing>Flow_IOT2</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Activity_SendEventMQTT" name="Send Event">
      <bpmn:incoming>Flow_IOT2</bpmn:incoming>
    </bpmn:task>
    <bpmn:task id="Activity_StartStreaming" name="Start Video Streaming">
      <bpmn:outgoing>Flow_IOT3</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Activity_StreamVideo" name="Stream Video to Client">
      <bpmn:incoming>Flow_IOT3</bpmn:incoming>
    </bpmn:task>
    <bpmn:sequenceFlow id="Flow_IOT1" sourceRef="Activity_CaptureEvent" targetRef="Activity_PackageEvent" />
    <bpmn:sequenceFlow id="Flow_IOT2" sourceRef="Activity_PackageEvent" targetRef="Activity_SendEventMQTT" />
    <bpmn:sequenceFlow id="Flow_IOT3" sourceRef="Activity_StartStreaming" targetRef="Activity_StreamVideo" />
  </bpmn:process>
  <bpmn:process id="Process_EventProcessing" isExecutable="false">
    <bpmn:task id="Activity_IngestEvent" name="Ingest Event from Firmware">
      <bpmn:outgoing>Flow_EP1</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Activity_EnrichEvent" name="Enrich Event (device name, location, user)">
      <bpmn:incoming>Flow_EP1</bpmn:incoming>
      <bpmn:outgoing>Flow_EP2</bpmn:outgoing>
    </bpmn:task>
    <bpmn:exclusiveGateway id="Gateway_ShouldAlert" name="Should Send Alert?">
      <bpmn:incoming>Flow_EP2</bpmn:incoming>
      <bpmn:outgoing>Flow_EP3_Yes</bpmn:outgoing>
      <bpmn:outgoing>Flow_EP3_No</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:task id="Activity_TriggerAlert" name="Trigger Alert to Notification Service">
      <bpmn:incoming>Flow_EP3_Yes</bpmn:incoming>
      <bpmn:outgoing>Flow_EP4</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Activity_LogEvent" name="Log Event to History">
      <bpmn:incoming>Flow_EP4</bpmn:incoming>
      <bpmn:incoming>Flow_EP3_No</bpmn:incoming>
      <bpmn:outgoing>Flow_EP5</bpmn:outgoing>
    </bpmn:task>
    <bpmn:endEvent id="Event_EventLogged" name="Event logged">
      <bpmn:incoming>Flow_EP5</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="Flow_EP1" sourceRef="Activity_IngestEvent" targetRef="Activity_EnrichEvent" />
    <bpmn:sequenceFlow id="Flow_EP2" sourceRef="Activity_EnrichEvent" targetRef="Gateway_ShouldAlert" />
    <bpmn:sequenceFlow id="Flow_EP3_Yes" name="Yes" sourceRef="Gateway_ShouldAlert" targetRef="Activity_TriggerAlert" />
    <bpmn:sequenceFlow id="Flow_EP3_No" name="No" sourceRef="Gateway_ShouldAlert" targetRef="Activity_LogEvent" />
    <bpmn:sequenceFlow id="Flow_EP4" sourceRef="Activity_TriggerAlert" targetRef="Activity_LogEvent" />
    <bpmn:sequenceFlow id="Flow_EP5" sourceRef="Activity_LogEvent" targetRef="Event_EventLogged" />
  </bpmn:process>
  <bpmn:process id="Process_Notification" isExecutable="false">
    <bpmn:task id="Activity_ReceiveAlertRequest" name="Receive Alert Request">
      <bpmn:outgoing>Flow_N1</bpmn:outgoing>
    </bpmn:task>
    <bpmn:sequenceFlow id="Flow_N1" sourceRef="Activity_ReceiveAlertRequest" targetRef="Activity_FormatMessage" />
    <bpmn:task id="Activity_FormatMessage" name="Format Notification Message">
      <bpmn:incoming>Flow_N1</bpmn:incoming>
      <bpmn:outgoing>Flow_N3</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Activity_SendToPushService" name="Send to Push Service">
      <bpmn:incoming>Flow_N3</bpmn:incoming>
    </bpmn:task>
    <bpmn:sequenceFlow id="Flow_N3" sourceRef="Activity_FormatMessage" targetRef="Activity_SendToPushService" />
  </bpmn:process>
  <bpmn:process id="Process_PushService" isExecutable="false">
    <bpmn:task id="Activity_ReceiveFromSecureNet" name="Receive from SecureNet">
      <bpmn:outgoing>Flow_PS1</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Activity_DeliverToMobile" name="Deliver to User&#39;s Mobile Device">
      <bpmn:incoming>Flow_PS1</bpmn:incoming>
    </bpmn:task>
    <bpmn:sequenceFlow id="Flow_PS1" sourceRef="Activity_ReceiveFromSecureNet" targetRef="Activity_DeliverToMobile" />
  </bpmn:process>
  <bpmn:process id="Process_Homeowner" isExecutable="false">
    <bpmn:task id="Activity_ReceiveNotification" name="Receive Push Notification">
      <bpmn:outgoing>Flow_H1</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Activity_OpenApp" name="Tap Notification, Open App">
      <bpmn:incoming>Flow_H1</bpmn:incoming>
      <bpmn:outgoing>Flow_H2</bpmn:outgoing>
    </bpmn:task>
    <bpmn:endEvent id="Event_ViewingFeed" name="Viewing live camera feed">
      <bpmn:incoming>Flow_H2</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="Flow_H1" sourceRef="Activity_ReceiveNotification" targetRef="Activity_OpenApp" />
    <bpmn:sequenceFlow id="Flow_H2" sourceRef="Activity_OpenApp" targetRef="Event_ViewingFeed" />
  </bpmn:process>
  <bpmn:process id="Process_ClientApp" isExecutable="false">
    <bpmn:task id="Activity_AppOpens" name="App Opens to Event View">
      <bpmn:outgoing>Flow_CA1</bpmn:outgoing>
    </bpmn:task>
    <bpmn:sequenceFlow id="Flow_CA1" sourceRef="Activity_AppOpens" targetRef="Activity_RequestLiveFeed" />
    <bpmn:sequenceFlow id="Flow_CA2" sourceRef="Activity_RequestLiveFeed" targetRef="Activity_DisplayFeed" />
    <bpmn:task id="Activity_DisplayFeed" name="Display Live Video Feed">
      <bpmn:incoming>Flow_CA2</bpmn:incoming>
    </bpmn:task>
    <bpmn:task id="Activity_RequestLiveFeed" name="Request Live Camera Feed">
      <bpmn:incoming>Flow_CA1</bpmn:incoming>
      <bpmn:outgoing>Flow_CA2</bpmn:outgoing>
    </bpmn:task>
  </bpmn:process>
  <bpmn:process id="Process_APIGateway" isExecutable="false">
    <bpmn:sequenceFlow id="Flow_AG2" sourceRef="Activity_AuthenticateUser" targetRef="Activity_RequestStream" />
    <bpmn:sequenceFlow id="Flow_AG1" sourceRef="Activity_ReceiveFeedRequest" targetRef="Activity_AuthenticateUser" />
    <bpmn:task id="Activity_RequestStream" name="Request Stream from Device">
      <bpmn:incoming>Flow_AG2</bpmn:incoming>
    </bpmn:task>
    <bpmn:task id="Activity_AuthenticateUser" name="Authenticate User">
      <bpmn:incoming>Flow_AG1</bpmn:incoming>
      <bpmn:outgoing>Flow_AG2</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Activity_ReceiveFeedRequest" name="Receive Live Feed Request">
      <bpmn:outgoing>Flow_AG1</bpmn:outgoing>
    </bpmn:task>
  </bpmn:process>
  <bpmn:process id="Process_DataStorage" isExecutable="false">
    <bpmn:task id="Activity_StoreEvent" name="Store Event in DB" />
  </bpmn:process>
  <bpmndi:BPMNDiagram id="BPMNDiagram_1">
    <bpmndi:BPMNPlane id="BPMNPlane_1" bpmnElement="Collaboration_MotionAlert">
