      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Activity_AuthenticateUser_di" bpmnElement="Activity_AuthenticateUser">
        <dc:Bounds x="930" y="1100" width="120" height="60" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Activity_RequestStream_di" bpmnElement="Activity_RequestStream">
        <dc:Bounds x="1100" y="1100" width="120" height="60" />
        <bpmndi:BPMNLabel />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNEdge id="Flow_AG1_di" bpmnElement="Flow_AG1">
