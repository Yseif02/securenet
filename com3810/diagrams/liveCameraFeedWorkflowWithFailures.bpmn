<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" xmlns:modeler="http://camunda.org/schema/modeler/1.0" id="Definitions_LiveFeed" targetNamespace="http://bpmn.io/schema/bpmn" exporter="Camunda Modeler" exporterVersion="5.44.0">
  <bpmn:collaboration id="Collaboration_LiveFeed">
    <bpmn:participant id="Participant_Homeowner" name="Homeowner" processRef="Process_Homeowner" />
    <bpmn:participant id="Participant_ClientApp" name="Client Application" processRef="Process_ClientApp" />
    <bpmn:participant id="Participant_APIGateway" name="API Gateway" processRef="Process_APIGateway" />
    <bpmn:participant id="Participant_DeviceMgmt" name="Device Management Service" processRef="Process_DeviceMgmt" />
    <bpmn:participant id="Participant_VideoService" name="Video Streaming Service" processRef="Process_VideoService" />
    <bpmn:participant id="Participant_IoTFirmware" name="IoT Device Firmware (Camera)" processRef="Process_IoTFirmware" />
    <bpmn:messageFlow id="Flow_HomeownerToApp" sourceRef="Activity_SelectCamera" targetRef="Activity_AppReceivesSelection" />
    <bpmn:messageFlow id="Flow_AppToGateway" sourceRef="Activity_0orontt" targetRef="Activity_ReceiveFeedRequest" />
    <bpmn:messageFlow id="Flow_GatewayToDeviceMgmt" sourceRef="Activity_RequestStream" targetRef="Activity_ReceiveRequest" />
    <bpmn:messageFlow id="Flow_DeviceMgmtToFirmware" sourceRef="Activity_SendStreamRequest" targetRef="Activity_ReceiveStreamRequest" />
    <bpmn:messageFlow id="Flow_FirmwareToVideoService" sourceRef="Activity_StreamVideo" targetRef="Activity_IngestStream" />
    <bpmn:messageFlow id="Flow_AppToVideoService" sourceRef="Activity_RequestChunks" targetRef="Activity_ReceiveChunkRequest" />
    <bpmn:messageFlow id="Flow_VideoServiceToApp" sourceRef="Activity_StreamChunks" targetRef="Activity_ReceiveChunks" />
    <bpmn:messageFlow id="Flow_VideoToHomeowner" sourceRef="Activity_RenderVideo" targetRef="Activity_WatchFeed" />
    <bpmn:messageFlow id="Flow_FirmwareOfflineToDeviceMgmt" sourceRef="Activity_RecordLocally" targetRef="Activity_MarkDeviceOffline" />
    <bpmn:messageFlow id="Flow_DeviceMgmtOfflineToApp" sourceRef="Activity_MarkDeviceOffline" targetRef="Activity_ShowOfflineStatus" />
    <bpmn:messageFlow id="Flow_FirmwareSyncToVideoService" sourceRef="Activity_SyncBufferedFootage" targetRef="Activity_IngestSyncedFootage" />
    <bpmn:messageFlow id="Flow_AppCachedToHomeowner" sourceRef="Activity_ShowCachedStatus" targetRef="Activity_SeeCachedWarning" />
    <bpmn:messageFlow id="Flow_VideoServiceBandwidthToApp" sourceRef="Activity_ReduceQuality" targetRef="Activity_ShowReducedQuality" />
    <bpmn:messageFlow id="Flow_02ckjug" sourceRef="Activity_1szsssh" targetRef="Activity_0nsupxq" />
    <bpmn:messageFlow id="Flow_06cizzc" sourceRef="Activity_05smwqe" targetRef="Activity_ShowCachedStatus" />
    <bpmn:textAnnotation id="TextAnnotation_Title">
      <bpmn:text>User Views Live Camera Feed Workflow (with Failure Scenarios)</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:association id="Association_Title" sourceRef="Participant_Homeowner" targetRef="TextAnnotation_Title" />
  </bpmn:collaboration>
  <bpmn:process id="Process_Homeowner" isExecutable="false">
    <bpmn:startEvent id="Event_Start" name="User wants to view camera">
      <bpmn:outgoing>Flow_H1</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:task id="Activity_OpenApp" name="Open Mobile/Web App">
      <bpmn:incoming>Flow_H1</bpmn:incoming>
      <bpmn:outgoing>Flow_H2</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Activity_SelectCamera" name="Select Camera from Dashboard">
      <bpmn:incoming>Flow_H2</bpmn:incoming>
      <bpmn:outgoing>Flow_H3</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Activity_WatchFeed" name="Watch Live Feed">
      <bpmn:incoming>Flow_H3</bpmn:incoming>
      <bpmn:outgoing>Flow_H4</bpmn:outgoing>
    </bpmn:task>
    <bpmn:endEvent id="Event_End" name="Viewing live feed">
      <bpmn:incoming>Flow_H4</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:task id="Activity_SeeCachedWarning" name="See Cached Status Warning">
      <bpmn:outgoing>Flow_H_CachedEnd</bpmn:outgoing>
    </bpmn:task>
    <bpmn:endEvent id="Event_CachedEnd" name="Remote control unavailable">
      <bpmn:incoming>Flow_H_CachedEnd</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="Flow_H1" sourceRef="Event_Start" targetRef="Activity_OpenApp" />
    <bpmn:sequenceFlow id="Flow_H2" sourceRef="Activity_OpenApp" targetRef="Activity_SelectCamera" />
    <bpmn:sequenceFlow id="Flow_H3" sourceRef="Activity_SelectCamera" targetRef="Activity_WatchFeed" />
    <bpmn:sequenceFlow id="Flow_H4" sourceRef="Activity_WatchFeed" targetRef="Event_End" />
    <bpmn:sequenceFlow id="Flow_H_CachedEnd" sourceRef="Activity_SeeCachedWarning" targetRef="Event_CachedEnd" />
  </bpmn:process>
  <bpmn:process id="Process_ClientApp" isExecutable="false">
    <bpmn:task id="Activity_InitPlayer" name="Initialize Player">
      <bpmn:incoming>Flow_06xepyc</bpmn:incoming>
      <bpmn:outgoing>Flow_CA3</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Activity_RequestChunks" name="Request Chunks">
      <bpmn:incoming>Flow_CA3</bpmn:incoming>
      <bpmn:outgoing>Flow_CA4</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Activity_ReceiveChunks" name="Receive Chunks">
      <bpmn:incoming>Flow_CA4</bpmn:incoming>
      <bpmn:outgoing>Flow_CA5</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Activity_RenderVideo" name="Render Video">
      <bpmn:incoming>Flow_CA5</bpmn:incoming>
      <bpmn:outgoing>Flow_CA_QualityCheck</bpmn:outgoing>
    </bpmn:task>
    <bpmn:exclusiveGateway id="Gateway_BWRestored" name="Bandwidth Improved?">
      <bpmn:incoming>Flow_CA_MonitorBW</bpmn:incoming>
      <bpmn:outgoing>Flow_CA_BWRestored</bpmn:outgoing>
      <bpmn:outgoing>Flow_CA_BWStillLow</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:task id="Activity_ShowOfflineStatus" name="Show Device Offline Status" />
    <bpmn:sequenceFlow id="Flow_CA1" sourceRef="Activity_AppReceivesSelection" targetRef="Activity_RequestLiveFeed" />
    <bpmn:sequenceFlow id="Flow_CA_ServiceCheck" sourceRef="Activity_RequestLiveFeed" targetRef="Gateway_ServiceAvailable" />
    <bpmn:sequenceFlow id="Flow_CA_ServiceNo" name="Unavailable" sourceRef="Gateway_ServiceAvailable" targetRef="Activity_ShowCachedStatus" />
    <bpmn:sequenceFlow id="Flow_CA3" sourceRef="Activity_InitPlayer" targetRef="Activity_RequestChunks" />
    <bpmn:sequenceFlow id="Flow_CA4" sourceRef="Activity_RequestChunks" targetRef="Activity_ReceiveChunks" />
    <bpmn:sequenceFlow id="Flow_CA5" sourceRef="Activity_ReceiveChunks" targetRef="Activity_RenderVideo" />
    <bpmn:sequenceFlow id="Flow_CA_QualityCheck" sourceRef="Activity_RenderVideo" targetRef="Gateway_BandwidthOK" />
    <bpmn:sequenceFlow id="Flow_CA_MonitorBW" sourceRef="Activity_ShowReducedQuality" targetRef="Gateway_BWRestored" />
    <bpmn:sequenceFlow id="Flow_CA_BWRestored" name="Yes" sourceRef="Gateway_BWRestored" targetRef="Event_CA_BWRestored" />
    <bpmn:sequenceFlow id="Flow_CA_BWStillLow" name="No" sourceRef="Gateway_BWRestored" targetRef="Event_CA_LowBW" />
    <bpmn:task id="Activity_0nsupxq" name="Receive Reconnected Notification and Show Device Online Status" />
    <bpmn:sequenceFlow id="Flow_CA_BWNo" name="No" sourceRef="Gateway_BandwidthOK" targetRef="Activity_ShowReducedQuality" />
    <bpmn:sequenceFlow id="Flow_CA_BWYes" name="Yes" sourceRef="Gateway_BandwidthOK" targetRef="Event_CA_End" />
    <bpmn:endEvent id="Event_CA_LowBW" name="Streaming at reduced quality">
      <bpmn:incoming>Flow_CA_BWStillLow</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:endEvent id="Event_CA_BWRestored" name="Quality auto-upgraded">
      <bpmn:incoming>Flow_CA_BWRestored</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:task id="Activity_ShowReducedQuality" name="Display Stream at Reduced Quality">
      <bpmn:incoming>Flow_CA_BWNo</bpmn:incoming>
      <bpmn:outgoing>Flow_CA_MonitorBW</bpmn:outgoing>
    </bpmn:task>
    <bpmn:endEvent id="Event_CA_End" name="Streaming at full quality">
      <bpmn:incoming>Flow_CA_BWYes</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:exclusiveGateway id="Gateway_BandwidthOK" name="Bandwidth Sufficient?">
      <bpmn:incoming>Flow_CA_QualityCheck</bpmn:incoming>
      <bpmn:outgoing>Flow_CA_BWYes</bpmn:outgoing>
      <bpmn:outgoing>Flow_CA_BWNo</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:task id="Activity_ShowCachedStatus" name="Show Cached Device Status with Warning">
      <bpmn:incoming>Flow_CA_ServiceNo</bpmn:incoming>
    </bpmn:task>
    <bpmn:task id="Activity_0orontt" name="Send Live Camera Feed Request to Gateway">
      <bpmn:incoming>Flow_1p2al3n</bpmn:incoming>
      <bpmn:outgoing>Flow_06xepyc</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Activity_RequestLiveFeed" name="Request Live Camera Feed">
      <bpmn:incoming>Flow_CA1</bpmn:incoming>
      <bpmn:outgoing>Flow_CA_ServiceCheck</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Activity_AppReceivesSelection" name="App Opens to Event View">
      <bpmn:outgoing>Flow_CA1</bpmn:outgoing>
    </bpmn:task>
    <bpmn:exclusiveGateway id="Gateway_ServiceAvailable" name="Cloud Service Available?">
      <bpmn:incoming>Flow_CA_ServiceCheck</bpmn:incoming>
      <bpmn:outgoing>Flow_CA_ServiceNo</bpmn:outgoing>
      <bpmn:outgoing>Flow_1p2al3n</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:sequenceFlow id="Flow_1p2al3n" name="Available" sourceRef="Gateway_ServiceAvailable" targetRef="Activity_0orontt" />
    <bpmn:sequenceFlow id="Flow_06xepyc" sourceRef="Activity_0orontt" targetRef="Activity_InitPlayer" />
  </bpmn:process>
  <bpmn:process id="Process_APIGateway" isExecutable="false">
    <bpmn:task id="Activity_RequestStream" name="Request Stream from DMS">
      <bpmn:incoming>Flow_AG_Healthy</bpmn:incoming>
    </bpmn:task>
    <bpmn:exclusiveGateway id="Gateway_ServiceHealth" name="Service Healthy?">
      <bpmn:incoming>Flow_AG_HealthCheck</bpmn:incoming>
      <bpmn:incoming>Flow_1fm9twa</bpmn:incoming>
      <bpmn:outgoing>Flow_AG_Healthy</bpmn:outgoing>
      <bpmn:outgoing>Flow_1skt8ft</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:task id="Activity_RouteToHealthyInstance" name="Route to Healthy Instance (Load Balancer)">
      <bpmn:incoming>Flow_0w0q5zj</bpmn:incoming>
      <bpmn:outgoing>Flow_AG_LogIncident</bpmn:outgoing>
      <bpmn:outgoing>Flow_1fm9twa</bpmn:outgoing>
    </bpmn:task>
    <bpmn:sequenceFlow id="Flow_AG_Healthy" name="Yes" sourceRef="Gateway_ServiceHealth" targetRef="Activity_RequestStream" />
    <bpmn:sequenceFlow id="Flow_AG1" sourceRef="Activity_ReceiveFeedRequest" targetRef="Activity_AuthenticateUser" />
    <bpmn:sequenceFlow id="Flow_AG_HealthCheck" sourceRef="Activity_AuthenticateUser" targetRef="Gateway_ServiceHealth" />
    <bpmn:sequenceFlow id="Flow_1fm9twa" sourceRef="Activity_RouteToHealthyInstance" targetRef="Gateway_ServiceHealth" />
    <bpmn:sequenceFlow id="Flow_AG_LogIncident" sourceRef="Activity_RouteToHealthyInstance" targetRef="Activity_LogIncident" />
    <bpmn:sequenceFlow id="Flow_1skt8ft" name="No" sourceRef="Gateway_ServiceHealth" targetRef="Gateway_1feiurf" />
    <bpmn:exclusiveGateway id="Gateway_1feiurf" name="Another healthy Instance?">
      <bpmn:incoming>Flow_1skt8ft</bpmn:incoming>
      <bpmn:outgoing>Flow_0w0q5zj</bpmn:outgoing>
      <bpmn:outgoing>Flow_1dkxpsi</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:sequenceFlow id="Flow_0w0q5zj" name="Yes" sourceRef="Gateway_1feiurf" targetRef="Activity_RouteToHealthyInstance" />
    <bpmn:task id="Activity_ReceiveFeedRequest" name="Receive Live Feed Request">
      <bpmn:outgoing>Flow_AG1</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Activity_AuthenticateUser" name="Authenticate User">
      <bpmn:incoming>Flow_AG1</bpmn:incoming>
      <bpmn:outgoing>Flow_AG_HealthCheck</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Activity_05smwqe" name="Log no&#10;Healthy Instances">
      <bpmn:incoming>Flow_1dkxpsi</bpmn:incoming>
    </bpmn:task>
    <bpmn:sequenceFlow id="Flow_1dkxpsi" name="No" sourceRef="Gateway_1feiurf" targetRef="Activity_05smwqe" />
    <bpmn:task id="Activity_LogIncident" name="Log Service Incident">
      <bpmn:incoming>Flow_AG_LogIncident</bpmn:incoming>
    </bpmn:task>
  </bpmn:process>
  <bpmn:process id="Process_DeviceMgmt" isExecutable="false">
    <bpmn:task id="Activity_ReceiveRequest" name="Receive Request">
      <bpmn:outgoing>Flow_DM1</bpmn:outgoing>
    </bpmn:task>
    <bpmn:exclusiveGateway id="Gateway_DeviceOnline" name="Device Online?">
      <bpmn:incoming>Flow_DM1</bpmn:incoming>
      <bpmn:outgoing>Flow_DM2_Yes</bpmn:outgoing>
      <bpmn:outgoing>Flow_DM2_No</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:task id="Activity_SendStreamRequest" name="Send Live Feed Request">
      <bpmn:incoming>Flow_DM2_Yes</bpmn:incoming>
    </bpmn:task>
    <bpmn:task id="Activity_MarkDeviceOffline" name="Mark Device Offline in Registry">
      <bpmn:incoming>Flow_DM2_No</bpmn:incoming>
      <bpmn:outgoing>Flow_1bula3i</bpmn:outgoing>
      <bpmn:outgoing>Flow_0sgeax7</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Activity_1d99b0h" name="Attempt Reconnection&#10;(Exponential Backoff)">
      <bpmn:incoming>Flow_051vxck</bpmn:incoming>
      <bpmn:incoming>Flow_0sgeax7</bpmn:incoming>
      <bpmn:outgoing>Flow_0h23coy</bpmn:outgoing>
    </bpmn:task>
    <bpmn:exclusiveGateway id="Gateway_1edyikt" name="Reconnected?">
      <bpmn:incoming>Flow_0h23coy</bpmn:incoming>
      <bpmn:outgoing>Flow_051vxck</bpmn:outgoing>
      <bpmn:outgoing>Flow_1vuv351</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:task id="Activity_1szsssh" name="Mark Device Online in Registry">
      <bpmn:incoming>Flow_1vuv351</bpmn:incoming>
    </bpmn:task>
    <bpmn:sequenceFlow id="Flow_DM1" sourceRef="Activity_ReceiveRequest" targetRef="Gateway_DeviceOnline" />
    <bpmn:sequenceFlow id="Flow_DM2_Yes" name="Yes" sourceRef="Gateway_DeviceOnline" targetRef="Activity_SendStreamRequest" />
    <bpmn:sequenceFlow id="Flow_DM2_No" name="No" sourceRef="Gateway_DeviceOnline" targetRef="Activity_MarkDeviceOffline" />
    <bpmn:sequenceFlow id="Flow_1bula3i" sourceRef="Activity_MarkDeviceOffline" targetRef="Event_DeviceOffline" />
    <bpmn:sequenceFlow id="Flow_0sgeax7" sourceRef="Activity_MarkDeviceOffline" targetRef="Activity_1d99b0h" />
    <bpmn:sequenceFlow id="Flow_051vxck" name="No" sourceRef="Gateway_1edyikt" targetRef="Activity_1d99b0h" />
    <bpmn:sequenceFlow id="Flow_0h23coy" sourceRef="Activity_1d99b0h" targetRef="Gateway_1edyikt" />
    <bpmn:sequenceFlow id="Flow_1vuv351" name="Yes" sourceRef="Gateway_1edyikt" targetRef="Activity_1szsssh" />
    <bpmn:endEvent id="Event_DeviceOffline" name="Error: Offline">
      <bpmn:incoming>Flow_1bula3i</bpmn:incoming>
      <bpmn:errorEventDefinition id="ErrorDef_Offline" />
    </bpmn:endEvent>
  </bpmn:process>
  <bpmn:process id="Process_VideoService" isExecutable="false">
    <bpmn:task id="Activity_IngestStream" name="Ingest Live Stream">
      <bpmn:outgoing>Flow_VS1</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Activity_BufferStream" name="Buffer Stream">
      <bpmn:incoming>Flow_VS1</bpmn:incoming>
      <bpmn:outgoing>Flow_VS2</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Activity_ReceiveChunkRequest" name="Receive Chunk Request">
      <bpmn:incoming>Flow_VS2</bpmn:incoming>
      <bpmn:outgoing>Flow_VS_BWCheck</bpmn:outgoing>
    </bpmn:task>
    <bpmn:exclusiveGateway id="Gateway_Bandwidth" name="Bandwidth Sufficient?">
      <bpmn:incoming>Flow_VS_BWCheck</bpmn:incoming>
      <bpmn:outgoing>Flow_VS_BWYes</bpmn:outgoing>
      <bpmn:outgoing>Flow_VS_BWNo</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:task id="Activity_StreamChunks" name="Stream Chunks (HD)">
      <bpmn:incoming>Flow_VS_BWYes</bpmn:incoming>
    </bpmn:task>
    <bpmn:task id="Activity_ReduceQuality" name="Reduce Stream Quality">
      <bpmn:incoming>Flow_VS_BWNo</bpmn:incoming>
      <bpmn:outgoing>Flow_VS_StreamLow</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Activity_StreamLowQuality" name="Stream Chunks (Low Resolution)">
      <bpmn:incoming>Flow_VS_StreamLow</bpmn:incoming>
      <bpmn:outgoing>Flow_VS_MonitorBW</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Activity_IngestSyncedFootage" name="Ingest Synced Buffered Footage" />
    <bpmn:exclusiveGateway id="Gateway_BWRecovered" name="Bandwidth Recovered?">
      <bpmn:incoming>Flow_VS_MonitorBW</bpmn:incoming>
      <bpmn:outgoing>Flow_VS_Recovered</bpmn:outgoing>
      <bpmn:outgoing>Flow_VS_StillLow</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:task id="Activity_RestoreQuality" name="Restore HD Quality">
      <bpmn:incoming>Flow_VS_Recovered</bpmn:incoming>
    </bpmn:task>
    <bpmn:endEvent id="Event_VS_StillLow" name="Continue low-quality stream">
      <bpmn:incoming>Flow_VS_StillLow</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="Flow_VS1" sourceRef="Activity_IngestStream" targetRef="Activity_BufferStream" />
    <bpmn:sequenceFlow id="Flow_VS2" sourceRef="Activity_BufferStream" targetRef="Activity_ReceiveChunkRequest" />
    <bpmn:sequenceFlow id="Flow_VS_BWCheck" sourceRef="Activity_ReceiveChunkRequest" targetRef="Gateway_Bandwidth" />
    <bpmn:sequenceFlow id="Flow_VS_BWYes" name="Yes" sourceRef="Gateway_Bandwidth" targetRef="Activity_StreamChunks" />
    <bpmn:sequenceFlow id="Flow_VS_BWNo" name="No" sourceRef="Gateway_Bandwidth" targetRef="Activity_ReduceQuality" />
    <bpmn:sequenceFlow id="Flow_VS_StreamLow" sourceRef="Activity_ReduceQuality" targetRef="Activity_StreamLowQuality" />
    <bpmn:sequenceFlow id="Flow_VS_MonitorBW" sourceRef="Activity_StreamLowQuality" targetRef="Gateway_BWRecovered" />
    <bpmn:sequenceFlow id="Flow_VS_Recovered" name="Yes" sourceRef="Gateway_BWRecovered" targetRef="Activity_RestoreQuality" />
    <bpmn:sequenceFlow id="Flow_VS_StillLow" name="No" sourceRef="Gateway_BWRecovered" targetRef="Event_VS_StillLow" />
  </bpmn:process>
  <bpmn:process id="Process_IoTFirmware" isExecutable="false">
    <bpmn:task id="Activity_ReceiveStreamRequest" name="Receive Request">
      <bpmn:outgoing>Flow_IOT1</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Activity_ValidateRequest" name="Validate Request">
      <bpmn:incoming>Flow_IOT1</bpmn:incoming>
      <bpmn:outgoing>Flow_IOT_WiFiCheck</bpmn:outgoing>
    </bpmn:task>
    <bpmn:exclusiveGateway id="Gateway_WiFiOK" name="WiFi Connected?">
      <bpmn:incoming>Flow_IOT_WiFiCheck</bpmn:incoming>
      <bpmn:incoming>Flow_IOT_BackoffRetry</bpmn:incoming>
      <bpmn:outgoing>Flow_IOT_WiFiYes</bpmn:outgoing>
      <bpmn:outgoing>Flow_IOT_WiFiNo</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:task id="Activity_StreamVideo" name="Stream Video">
      <bpmn:incoming>Flow_IOT_WiFiYes</bpmn:incoming>
    </bpmn:task>
    <bpmn:task id="Activity_RecordLocally" name="Record to Local Buffer / Storage">
      <bpmn:incoming>Flow_IOT_WiFiNo</bpmn:incoming>
      <bpmn:outgoing>Flow_IOT_Backoff</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Activity_ExponentialBackoff" name="Attempt Reconnection (Exponential Backoff)">
      <bpmn:incoming>Flow_IOT_Backoff</bpmn:incoming>
      <bpmn:outgoing>Flow_IOT_BackoffRetry</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Activity_SyncBufferedFootage" name="Sync Buffered Footage to Cloud">
      <bpmn:incoming>Flow_IOT_SyncTrigger</bpmn:incoming>
    </bpmn:task>
    <bpmn:sequenceFlow id="Flow_IOT1" sourceRef="Activity_ReceiveStreamRequest" targetRef="Activity_ValidateRequest" />
    <bpmn:sequenceFlow id="Flow_IOT_WiFiCheck" sourceRef="Activity_ValidateRequest" targetRef="Gateway_WiFiOK" />
    <bpmn:sequenceFlow id="Flow_IOT_BackoffRetry" sourceRef="Activity_ExponentialBackoff" targetRef="Gateway_WiFiOK" />
    <bpmn:sequenceFlow id="Flow_IOT_WiFiYes" name="Connected" sourceRef="Gateway_WiFiOK" targetRef="Activity_StreamVideo" />
    <bpmn:sequenceFlow id="Flow_IOT_WiFiNo" name="Lost" sourceRef="Gateway_WiFiOK" targetRef="Activity_RecordLocally" />
    <bpmn:sequenceFlow id="Flow_IOT_SyncTrigger" sourceRef="Activity_StreamVideo" targetRef="Activity_SyncBufferedFootage" />
    <bpmn:sequenceFlow id="Flow_IOT_Backoff" sourceRef="Activity_RecordLocally" targetRef="Activity_ExponentialBackoff" />
  </bpmn:process>
  <bpmndi:BPMNDiagram id="BPMNDiagram_1">
    <bpmndi:BPMNPlane id="BPMNPlane_1" bpmnElement="Collaboration_LiveFeed">
      <bpmndi:BPMNShape id="Participant_Homeowner_di" bpmnElement="Participant_Homeowner" isHorizontal="true">
