    </bpmn:task>
    <bpmn:task id="Activity_MarkOnline" name="Mark Device as Online">
      <bpmn:incoming>Flow_DM6</bpmn:incoming>
    </bpmn:task>
    <bpmn:sequenceFlow id="Flow_DM1" sourceRef="Activity_CreateDevice" targetRef="Activity_GenerateCredentials" />
