      <bpmn:incoming>Flow_CA4</bpmn:incoming>
      <bpmn:outgoing>Flow_CA5</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Activity_GuideWiFi" name="Guide User Through WiFi Setup">
      <bpmn:incoming>Flow_CA5</bpmn:incoming>
      <bpmn:outgoing>Flow_CA6</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Activity_DisplayDashboard" name="Display Device in Dashboard">
      <bpmn:incoming>Flow_CA6</bpmn:incoming>
    </bpmn:task>
    <bpmn:sequenceFlow id="Flow_CA2" sourceRef="Activity_PromptScan" targetRef="Activity_ValidateQR" />
    <bpmn:sequenceFlow id="Flow_CA3" sourceRef="Activity_ValidateQR" targetRef="Activity_SendRegistration" />
    <bpmn:sequenceFlow id="Flow_CA4" sourceRef="Activity_SendRegistration" targetRef="Activity_ReceiveDeviceIDApp" />
    <bpmn:sequenceFlow id="Flow_CA5" sourceRef="Activity_ReceiveDeviceIDApp" targetRef="Activity_GuideWiFi" />
    <bpmn:sequenceFlow id="Flow_CA6" sourceRef="Activity_GuideWiFi" targetRef="Activity_DisplayDashboard" />
  </bpmn:process>
  <bpmn:process id="Process_APIGateway" isExecutable="false">
